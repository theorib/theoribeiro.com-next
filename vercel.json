{
  "framework": null,
  "buildCommand": "pnpm build",
  "outputDirectory": "out",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/about-theo-ribeiro-cinematographer",
      "destination": "/about-theo-ribeiro",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about-theo-ribeiro",
      "permanent": true
    },
    {
      "source": "/cinematography-demo-reel",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/portfolio/aerial-photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/portfolio/landscapes-and-places-photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/portfolio/natural-light-photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/portfolio/lifestyle-photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/portfolio/black-and-white-photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/red-bull-bc-one-all-stars-2012",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/photography",
      "destination": "/still-photography",
      "permanent": true
    },
    {
      "source": "/privacy-tools",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; connect-src 'self' https://*.mux.com https://*.litix.io https://storage.googleapis.com https://image.mux.com; media-src 'self' blob: https://*.mux.com; img-src 'self' blob: data: https://assets.theoribeiro.com https://image.mux.com https://*.litix.io; script-src 'self' 'unsafe-inline' https://src.litix.io https://www.gstatic.com; worker-src 'self' blob:; form-action 'self' https://*.mux.com https://storage.googleapis.com; style-src 'self' 'unsafe-inline'; frame-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
        }
      ]
    }
  ]
}
